#!/usr/bin/env bash
# Install and configure Nginx to serve "Holberton School for the win!" on port 80

# Update packages and install nginx
apt-get update -y
apt-get install -y nginx

# Ensure the /var/www/html directory exists
mkdir -p /var/www/html

# Overwrite the default index.html with our content
echo "Holberton School for the win!" > /var/www/html/index.html

# Start Nginx using the service command, restart if already running
service nginx restart


