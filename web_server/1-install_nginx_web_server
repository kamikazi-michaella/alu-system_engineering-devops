#!/usr/bin/env bash
# Installs and configures Nginx to serve "Holberton School for the win!" on port 80

# Update package list
apt-get update -y

# Install Nginx
apt-get install -y nginx

# Create the index page with the required content
echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

# Start Nginx service (without using systemctl)
service nginx start
